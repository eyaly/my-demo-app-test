<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Sauce Labs Cross Platform Suite" parallel="tests" thread-count="6" verbose="2">
    
    <test name="Android Test" parallel="methods" thread-count="6">
        <parameters>
            <parameter name="platformName" value="Android"/>
            <parameter name="platformVersion" value="16"/>
            <parameter name="deviceName" value="Samsung.*"/>
            <parameter name="app" value="storage:filename=androidMobileDemoApp.apk"/>
        </parameters>
        <classes>
            <class name="com.example.tests.SortTest"/>
            <class name="com.example.tests.ProductsTest"/>
        </classes>
    </test>

   <test name="iOS Test" parallel="methods" thread-count="6">
       <parameters>
           <parameter name="platformName" value="iOS"/>
           <parameter name="platformVersion" value="18"/>
           <parameter name="deviceName" value="iPhone.*"/>
           <parameter name="app" value="storage:filename=SauceLabs-Demo-App.ipa"/>
       </parameters>
       <classes>
            <class name="com.example.tests.SortTest"/>
           <class name="com.example.tests.ProductsTest"/>
       </classes>
   </test> 

</suite>
